# Clerk — https://dashboard.clerk.com (optional locally if middleware skips auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe — https://dashboard.stripe.com/apikeys (optional until you enable checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase — https://supabase.com/dashboard (optional until you enable CMS — admin list stays empty)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# After deploy: your live Astro URL (Stripe success/cancel). Local default is fine for dev.
NEXT_PUBLIC_SITE_URL=http://localhost:4321

# Resend — https://resend.com/api-keys (optional)
RESEND_API_KEY=
# Example: DEV.ECOM <billing@yourdomain.com>
RESEND_FROM=
