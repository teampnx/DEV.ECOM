---
import Layout from '@/layouts/Layout.astro';
import { TemplatesMarketplacePage } from '@/components/marketplace/TemplatesMarketplacePage';

const dashboardUrl = import.meta.env.PUBLIC_DASHBOARD_URL ?? '/dashboard';
---

<Layout
  title="Browse Shopify Templates — DEV.ECOM"
  description="Search and filter premium Shopify and Shopify Plus storefront themes. Live demos and instant licensing."
>
  <TemplatesMarketplacePage client:load dashboardUrl={dashboardUrl} />
</Layout>
